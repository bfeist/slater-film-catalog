# ============================================================
# NASA Slater Catalog — server environment variables
# Copy this file to .env and adjust paths for your machine.
# .env is gitignored; .env.example is committed.
#
# IMPORTANT: Node loads .env once at process startup.
# It will NOT override a variable already set in the shell environment.
# NODE_ENV is controlled by the npm scripts (cross-env), not here.
# ============================================================

# HTTP port the Express server listens on
PORT=3001

# ---------------------------------------------------------------------------
# Paths — adjust to match your machine or Docker volume mounts
# ---------------------------------------------------------------------------

# Absolute path to the SQLite catalog database
# Docker example:  DB_PATH=/data/01b_excel.db
DB_PATH=F:/_repos/nasa_slater_catalog/data/01b_excel.db

# Directory containing the scanned shotlist PDFs
# Docker example:  SHOTLIST_PDF_DIR=/shotlist-pdfs
SHOTLIST_PDF_DIR=F:/_repos/nasa_slater_catalog/input_indexes/MASTER FR shotlist folder

# Root of the NASA video archive share
# UNC example:    VIDEO_ARCHIVE_ROOT=\\\\192.168.0.6\\NASA Archive
# Docker example: VIDEO_ARCHIVE_ROOT=/archive  (volume: -v /mnt/nas:/archive)
VIDEO_ARCHIVE_ROOT=O:\

# Absolute path to a TrueType font used for the ffmpeg watermark
# Linux/Docker example:  WATERMARK_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
WATERMARK_FONT_PATH=C:/Windows/Fonts/arial.ttf

# Path to the built Vite SPA, served by Express in production
# Usually leave as the default .local/vite/dist
VITE_DIST_DIR=F:/_repos/nasa_slater_catalog/.local/vite/dist
