# =============================================================================
# Local development environment template
# Copy to .env and customize for your machine. .env is gitignored (safe for secrets).
# See config.ts for runtime defaults and variable descriptions.
# =============================================================================

# HTTP port Express listens on
PORT=3001

# ---------------------------------------------------------------------------
# Database & Archives (absolute paths or UNC paths)
# ---------------------------------------------------------------------------

# SQLite catalog database
DB_PATH=F:/_repos/nasa_slater_catalog/database/catalog.db

# Scanned shotlist PDFs
SHOTLIST_PDF_DIR=F:/_repos/nasa_slater_catalog/static_assets/shotlist_pdfs

# LLM OCR JSON outputs (one file per PDF)
LLM_OCR_DIR=F:/_repos/nasa_slater_catalog/static_assets/llm_ocr

# Root of the NASA video archive
# Windows (drive letter): O:\
# UNC path: \\\\192.168.0.6\\NASA Archive
# Docker: /archive (mounted CIFS volume)
VIDEO_ARCHIVE_ROOT=O:\

# ---------------------------------------------------------------------------
# Fonts (TrueType paths for ffmpeg watermark)
# ---------------------------------------------------------------------------

# Standard proportional font
# Windows: C:/Windows/Fonts/arial.ttf
# Linux: /usr/share/fonts/dejavu/DejaVuSans.ttf
WATERMARK_FONT_PATH=C:/Windows/Fonts/arial.ttf

# Monospace font (for timecode/frame overlay readability)
# Windows: C:/Windows/Fonts/lucon.ttf (Lucida Console)
# Linux: /usr/share/fonts/dejavu/DejaVuSansMono.ttf
WATERMARK_MONO_FONT_PATH=C:/Windows/Fonts/lucon.ttf

# ---------------------------------------------------------------------------
# Vite SPA (built frontend — only used if serving from Express)
# ---------------------------------------------------------------------------
VITE_DIST_DIR=F:/_repos/nasa_slater_catalog/.local/vite/dist

# ---------------------------------------------------------------------------
# NAS/SMB Share Credentials
# Used by docker-compose.yml to mount the archive as a CIFS volume.
# NOT passed to the running container; kept local on the Docker host.
# For anonymous/guest shares: NAS_USER=guest  NAS_PASS=
# ---------------------------------------------------------------------------
NAS_HOST=192.168.0.6
NAS_SHARE=NASA Archive
NAS_USER=
NAS_PASS=

# ---------------------------------------------------------------------------
# Secrets (keep stable — DO NOT CHANGE after DB creation)
# ---------------------------------------------------------------------------

# HMAC key for deriving Slater numbers (SFR-XXXXXX) from identifiers.
# The same key always produces the same numbers. Changing this will reassign
# all slater numbers, breaking any client bookmarks or external URLs.
# Min 32 chars recommended.
SLATER_SECRET=change-me-to-a-strong-random-value

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Directory for activity log files (gitignored if under .local/)
LOG_DIR=.local/logs

# Log level: off | error | warn | notice | info | debug
# info = startup messages + activity log + errors
# debug = + detailed ffmpeg/stream info
LOG_LEVEL=info
