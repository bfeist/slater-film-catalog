# =============================================================================
# Docker environment template
# Copy to .env.docker and adjust for your docker-compose.yml setup.
# Container-internal paths must match the volume mounts defined in compose.
# =============================================================================

# Runtime environment
NODE_ENV=production
PORT=9301

# ---------------------------------------------------------------------------
# Container-internal paths (match docker-compose.yml volume mounts)
# ---------------------------------------------------------------------------

# SQLite database
DB_PATH=/app/database/catalog.db

# Scanned shotlist PDFs
SHOTLIST_PDF_DIR=/app/static_assets/shotlist_pdfs

# LLM OCR outputs
LLM_OCR_DIR=/app/static_assets/llm_ocr

# Auth credentials (read-only mount)
AUTH_CONFIG_PATH=/app/auth.config.json

# Video archive root (CIFS volume mount)
VIDEO_ARCHIVE_ROOT=/archive

# ---------------------------------------------------------------------------
# Fonts (Alpine container has DejaVu pre-installed)
# ---------------------------------------------------------------------------
WATERMARK_FONT_PATH=/usr/share/fonts/dejavu/DejaVuSans.ttf
WATERMARK_MONO_FONT_PATH=/usr/share/fonts/dejavu/DejaVuSansMono.ttf

# ---------------------------------------------------------------------------
# Frontend & Logging
# ---------------------------------------------------------------------------

# Set to "false" when Nginx serves the SPA (recommended)
# Set to "true" for single-container mode (Express serves both API and SPA)
SERVE_FRONTEND=false

# Activity logs (writable volume mount)
LOG_DIR=/app/logs
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Secrets
# Must match the SLATER_SECRET from .env (copied here for container)
# ---------------------------------------------------------------------------
SLATER_SECRET=stephen-slater-nasa-catalog
